  "keyword": [
    {"words": ["PR #", "pull request", "merge request", "MR !"], "group": "dev"},
    {"words": ["bug", "ticket", "JIRA", "linear", "story point"], "group": "work"},
    {"words": ["recipe", "cooking", "baking", "dinner"], "group": "entertain"},
    {"words": ["sale", "deal", "discount", "coupon", "promo code"], "group": "shop"},
    {"words": ["tutorial", "guide", "how to", "getting started"], "group": "read"},
    {"words": ["API", "documentation", "reference", "manual"], "group": "dev"},
    {"words": ["login", "sign in", "sign up", "register"], "group": "tools"},
    {"words": ["error", "exception", "failed", "crash", "bug report"], "group": "dev"},
    {"words": ["invoice", "receipt", "order confirmation", "shipping"], "group": "shop"},
    {"words": ["meeting", "agenda", "minutes", "standup"], "group": "work"}
  ]
